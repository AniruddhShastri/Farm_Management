                % You should already have E (biogas power available) from your earlier calculation\
                remainingBiogasPower = E - biogasPowerNeeded;\
\
                if remainingBiogasPower < 0\
                    % Biogas is insufficient, calculate how much load reduction is needed\
                    reductionPercentage = ((biogasPowerNeeded - E) / biogasPowerNeeded) * 100;\
                    app.Label_3.Text = '';\
                    app.Label_4.Text = '';\
                    app.ChoicesifinsufficientbiomassButtonGroup.Enable = 'on';\
