\
            app.NumberofanimalsEditField.Value = 0;\
            app.AmountofbiomasstonsperdayEditField.Value = 0;\
            %app.DatePicker.Value = [];\
            app.TimeEditField.Value = 0;\
            app.PowerGeneratedLabel.Text = 'Click the "Convert into kWh" button to calculate electricity generated';\
            app.Comparison.Text = '';\
            app.Label.Text = '';\
            app.Label_2.Text = '';\
            app.Label_3.Text = '';\
            app.Label_4.Text = '';\
        end\
