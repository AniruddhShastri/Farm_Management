        % Button pushed function: GoButton\
        function GoButtonPushed(app, event)\
            file = fullfile("C:\\Users\\karth\\Desktop\\yearlyload.xlsx");\
            data = readmatrix(file);\
            PVData = data(:, 1); % Assuming PV data is in the first column\
            LoadData = data(:, 2); % Assuming load data is in the second column\
\
            % Get user inputs from the edit fields\
            numAnimals = app.NumberofanimalsEditField.Value;\
            amount = app.AmountofbiomasstonsperdayEditField.Value;\
            selectedDate = app.DatePicker.Value;\
            selectedTime = app.TimeEditField.Value;\
\
            daysSinceJan1 = days(datetime(selectedDate) - datetime(year(selectedDate), 1, 1)) + 1;\
            startRow = (daysSinceJan1 - 1) * 24 + 1;\
            endRow = startRow + 23;\
\
            if endRow > size(data, 1)\
               uialert(app.UIFigure, 'Selected date and time exceed data range in the Excel sheet.', 'Error', 'Icon', 'error');\
                return;\
            end\
\
            PVDataSelectedDay = PVData(startRow:endRow);\
            LoadDataSelectedDay = LoadData(startRow:endRow);\
\
            PVDataUntilSelectedTime = sum(PVDataSelectedDay(1:selectedTime));\
            LoadDataUntilSelectedTime = sum(LoadDataSelectedDay(1:selectedTime));\
\
            PV_kWh = PVDataUntilSelectedTime/1000;\
            Load_kWh = LoadDataUntilSelectedTime/1000;\
\
            % Determine energy produced based on animal type\
            animalType = app.CattleManureTypeDropDown.Value;\
\
            if strcmp(animalType, 'Dairy')\
                if numAnimals ~= 0 && amount == 0\
                    % Calculate energy based on number of animals\
                    B = numAnimals * 0.03 * 0.18 * ((0.396 * 400) + (0.16 * 0.181 * 497));\
                elseif numAnimals == 0 && amount ~= 0\
                    % Calculate energy based on biomass amount\
                    B = amount * 0.18 * ((0.396 * 400) + (0.16 * 0.181 * 497));\
                else\
                    % Display an error message if both or none of the fields have values\
                    uialert(app.UIFigure, 'Please enter values in either Number of animals or Amount of biomass.', 'Error', 'Icon', 'error');\
                    return;  % Exit the function without further calculations\
                end\
            elseif strcmp(animalType, 'Beef')\
                if numAnimals ~= 0 && amount == 0\
                    B = numAnimals * 0.029 * 0.18 * ((0.393 * 400) + (0.16 * 0.121 * 497));\
                elseif numAnimals == 0 && amount ~= 0\
                    B = amount * 0.18 * ((0.393 * 400) + (0.16 * 0.121 * 497));\
                else\
                    % Display an error message if both or none of the fields have values\
                    uialert(app.UIFigure, 'Please enter values in either Number of animals or Amount of biomass.', 'Error', 'Icon', 'error');\
                    return;  % Exit the function without further calculations\
                end\
            elseif strcmp(animalType, 'Feedlot')\
                if numAnimals ~= 0 && amount == 0\
                    B = numAnimals * 0.03 * 0.18 * ((0.356 * 400) + (0.16 * 0.17 * 497));\
                elseif numAnimals == 0 && amount ~= 0\
                    B = amount * 0.18 * ((0.356 * 400) + (0.16 * 0.17 * 497));\
                else\
                    % Display an error message if both or none of the fields have values\
                    uialert(app.UIFigure, 'Please enter values in either Number of animals or Amount of biomass.', 'Error', 'Icon', 'error');\
                    return;  % Exit the function without further calculations\
                end\
            end\
\
            % Calculate power generated\
            E = B * 22626 * 0.0002973071 * 0.35;\
\
            % Handle insufficient biogas power scenario\
\
            if PV_kWh >= Load_kWh\
                app.Label_3.Text = 'Solar power can satisfy the load, no need for biogas generator.';\
                app.Comparison.Text = sprintf('Surplus solar: %.2f kWh', PV_kWh - Load_kWh);\
                app.Label_4.Text = '';\
                app.ChoicesifinsufficientbiomassButtonGroup.Enable = 'off';\
            else\
                % Biogas is needed\
                biogasPowerNeeded = Load_kWh - PV_kWh;\
\
                % You should already have E (biogas power available) from your earlier calculation\
                remainingBiogasPower = E - biogasPowerNeeded;\
\
\
                if remainingBiogasPower < 0\
                    extraPowerNeeded = abs(remainingBiogasPower);\
\
                    if app.AddmorebiomassButton.Value\
                        % Calculate additional biomass required\
                        Biogasrequired = extraPowerNeeded / (22626 * 0.0002973071 * 0.4);\
                        additionalBiomass = Biogasrequired / (0.18 * ((0.396 * 400) + (0.16 * 0.181 * 497)));\
                        app.Comparison.Text = sprintf('Add %.2f tons of biomass to meet the power demand.', additionalBiomass);\
\
                        uialert(app.UIFigure, 'Do you have the necessary resources to bring in the biomass?', 'Resource Check', 'Icon', 'question');\
\
                    elseif app.UseDieselGeneratorButton.Value\
                        % Display message to use diesel generator\
                        app.Comparison.Text = sprintf('Use diesel generator to produce %.2f kWh of energy.', extraPowerNeeded);\
                    end\
                else\
                    app.Label.Text = 'Biogas generator can supply power for the entire day.';\
                end\
\
                % Display error message if something goes wrong\
                %uialert(app.UIFigure, ME.message, 'Error', 'Icon', 'error');\
            end\
\
        end\
