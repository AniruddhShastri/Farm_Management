# VONeng Environment Variables
# ─────────────────────────────────────────────
# Gemini AI API Key (get yours free at https://aistudio.google.com/apikey)
# The free Gemini 2.0 Flash tier handles 50,000+ conversations per day
VITE_GEMINI_API_KEY=

# ─────────────────────────────────────────────
# AbstractAPI — Email and Phone Validation
# Free tier: 100 email checks/month, 250 phone checks/month
# https://www.abstractapi.com
VITE_ABSTRACT_API_EMAIL_KEY=
VITE_ABSTRACT_API_PHONE_KEY=

# ─────────────────────────────────────────────
# Twilio Verify — SMS OTP for phone verification
# $0.05 per verification, only charged when a lead comes in
VITE_TWILIO_ACCOUNT_SID=
VITE_TWILIO_AUTH_TOKEN=
VITE_TWILIO_VERIFY_SERVICE_SID=

# ─────────────────────────────────────────────
# Firebase Config — Google Sign-In & Database
# Set up a project at https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
